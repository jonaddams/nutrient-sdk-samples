# Copy this file to .env.local and fill in the values you need.
#   cp env.sample .env.local
# Only the license key is required to run the Web SDK samples; the rest are
# only needed for the sample groups that call a backend (see README → Backends).

# --- Required: Nutrient license key (client-side) ---
NEXT_PUBLIC_NUTRIENT_LICENSE_KEY=

# --- SDK versions (client-side) ---
NEXT_PUBLIC_WEB_SDK_VERSION=1.12.0
NEXT_PUBLIC_DOCUMENT_AUTHORING_SDK_VERSION=1.10.0

# --- AI Document Processing (XtractFlow) ---
NEXT_PUBLIC_NUTRIENT_API_URL=https://api.xtractflow.com
NUTRIENT_AUTH_TOKEN=

# --- Nutrient DWS API ---
NUTRIENT_API_BASE_URL=https://api.nutrient.io/
NUTRIENT_API_KEY=

# --- Python SDK backend (defaults to http://localhost:8080) ---
# Source: https://github.com/jonaddams/python-fast-api
NEXT_PUBLIC_PYTHON_SDK_API_URL=http://localhost:8080

# --- Java SDK backend (defaults to http://localhost:8080) ---
NEXT_PUBLIC_JAVA_SDK_API_URL=http://localhost:8080

# --- .NET SDK backend ---
NEXT_PUBLIC_DOTNET_SDK_API_URL=https://nutrient-dotnet-api-production.up.railway.app
# Server-side only. Read by app/api/dotnet-sdk/* route handlers and forwarded to the .NET API.
DOTNET_SDK_API_KEY=replace-me

# --- Indexed search demo (Postgres) ---
# Used by lib/db.ts and the `pnpm index` / `pnpm seed-search` scripts.
DATABASE_URL=
# Direct (non-pooled) connection for seeding; falls back to DATABASE_URL if unset.
DATABASE_URL_UNPOOLED=
